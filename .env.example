# Nenhuma destas variáveis é obrigatória para rodar em desenvolvimento:
# sem um .env, a aplicação já sobe sozinha usando SQLite (arquivo app.db
# na raiz do projeto). Copie este arquivo para .env apenas quando quiser
# customizar algo (ex.: usar PostgreSQL, ou fazer deploy em produção).

# ---- Chave secreta (sempre defina uma própria em produção) ----
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-e-secreta

# ---- Banco de dados ----
# Deixe comentado para usar SQLite (padrão, zero configuração).
# Para PostgreSQL, descomente e ajuste:
# DATABASE_URL=postgresql+psycopg2://sca_user:sca_pass@localhost:5432/sca_db

# ---- Primeiro administrador (bootstrap automático de produção) ----
# Se definidas, o entrypoint.sh (ou `flask ensure-admin`) cria este admin
# automaticamente no primeiro boot — e não faz nada se já existir algum
# administrador. Sem isso, use `flask create-admin` manualmente.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=troque-por-uma-senha-forte

# ---- HTTPS / cookies seguros ----
# Só ative quando o site estiver servido via HTTPS de verdade (produção
# atrás de Nginx/Load Balancer com TLS).
# SESSION_COOKIE_SECURE=true
# TALISMAN_FORCE_HTTPS=true

# ---- Redis (opcional) ----
# Só necessário se você quiser compartilhar sessão/cache/rate-limit entre
# várias máquinas ou vários processos Gunicorn com muito tráfego. Sem
# isso, tudo funciona localmente em disco/memória.
# REDIS_URL=redis://localhost:6379/0
# SESSION_TYPE=redis
# CACHE_TYPE=RedisCache

# ---- Servidor (produção) ----
PORT=8000
GUNICORN_WORKERS=2

# ---- Atrás de um proxy reverso / CDN (Nginx, Render, Railway, Cloudflare) ----
# Praticamente TODO deploy real está atrás de algum proxy. Ative isto para
# que o Flask enxergue o IP verdadeiro do visitante (via X-Forwarded-For) em
# vez do IP do proxy — importante para a proteção de sessão do Flask-Login
# e para o rate limiting funcionarem corretamente por cliente. Só ative se
# tiver certeza de que apenas o SEU proxy consegue falar com o processo
# Flask/Gunicorn diretamente (senão, X-Forwarded-For pode ser falsificado).
TRUST_PROXY_HEADERS=true
